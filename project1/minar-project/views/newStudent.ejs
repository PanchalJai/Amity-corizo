<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/styles/style.css" rel="stylesheet" >
    <title>new student</title>
</head>
<body>
    <div class="container text-center text-white  ">
        <h1 class="">Students form</h1>
        <form action="http://localhost:5000/new" class="text-start offset-2"  method="post">
            <label for="name" class=" ">Name</label>
            <br>
            <input type="text" name="name" class=" rounded px-3 py-2 col-10 mb-3 fs-5"  >
            <br>
            <label for="rollNo" class=" " >Roll No.</label>
            <br>
            <input type="number" name="rollNo" class="rounded px-3 py-2 col-10 mb-3  fs-5">
            <br>
            <label for="class" class=" ">class</label>
             <br>
            <input type="text" name="class"  class="rounded px-3 py-2 col-10 mb-3 fs-5">
            <br>
            <label for="address" class=" ">Address</label>
            <br>
            <input type="text" name="address"  class="rounded px-3 py-2 col-10 mb-3  fs-5">
            <br>
            <button type="submit"  class="rounded px-3 py-2 col-10  fs-5 mt-3" >Submit</button>
        </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>